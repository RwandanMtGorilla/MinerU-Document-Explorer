*.mp4 filter=lfs diff=lfs merge=lfs -text

# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf

# Python files should use LF
*.py text eol=lf

# Batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# JSON/YAML/Markdown files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Config files
*.toml text eol=lf
*.txt text eol=lf
